# ==============================
#   INDECLOW by AxeroAI
#   Environment Configuration
# ==============================

# --- Telegram Bot ---
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Ollama ---
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
# Model to use (must be pulled via: ollama pull <model>)
OLLAMA_MODEL=llama3.2

# --- ngrok (Live Preview) ---
# Get free authtoken from https://dashboard.ngrok.com
NGROK_AUTH_TOKEN=your_ngrok_authtoken_here

# --- Project Settings ---
# Directory where generated projects are saved
PROJECTS_DIR=./projects
# Directory for skill installations
SKILLS_DIR=./skills
# Directory for logs
LOGS_DIR=./logs

# --- Agent Settings ---
# Max retries for LLM calls
MAX_LLM_RETRIES=3
# Timeout for terminal commands (seconds)
TERMINAL_TIMEOUT=60
# Max tokens per LLM response
MAX_TOKENS=4096
